---
const year = new Date().getFullYear();

const navLinks = [
  { href: '#', label: 'Inicio' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#testimonios', label: 'Reseñas' },
  { href: '#contacto', label: 'Reservar Turno' },
];
---

<footer style="background-color: #1a3c44;" class="text-white pt-10 pb-5 px-8">
  <div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-7">

    <!-- Columna 1: Marca -->
    <div class="flex flex-col gap-4 lg:col-span-1">
      <p class="font-extrabold text-base text-white" style="font-family: var(--font-sans);">Maskotitas Veterinaria</p>
      <p class="text-sm text-white/70 leading-relaxed" style="font-family: var(--font-sans);">
        Cuidado profesional y con amor para tus mejores amigos en San Juan.
      </p>
      <a
        href="https://www.instagram.com/maskotitasveterinaria"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-white/70 hover:text-white transition-colors w-fit"
        aria-label="Instagram de Maskotitas Veterinaria"
        style="font-family: var(--font-sans);"
      >
        <span class="material-symbols-outlined text-lg" aria-hidden="true">photo_camera</span>
        @maskotitasveterinaria
      </a>
    </div>

    <!-- Columna 2: Navegación -->
    <div class="flex flex-col gap-3">
      <h3 class="font-bold text-white text-sm mb-1" style="font-family: var(--font-sans);">Navegación</h3>
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-sm text-white/70 hover:text-white transition-colors"
          style="font-family: var(--font-sans);"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Columna 3: Contacto con WhatsApp -->
    <div class="flex flex-col gap-4">
      <h3 class="font-bold text-white text-sm mb-1" style="font-family: var(--font-sans);">Contacto</h3>

      <!-- Capital -->
      <div class="flex flex-col gap-1">
        <p class="text-sm text-white font-semibold" style="font-family: var(--font-sans);">Capital</p>
        <a
          href="https://wa.me/5492644704399"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-white/75 hover:text-white transition-colors"
          aria-label="WhatsApp Capital"
          style="font-family: var(--font-sans);"
        >
          <svg class="w-4 h-4 fill-current flex-shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          264 470-4399
        </a>
      </div>

      <!-- Chimbas -->
      <div class="flex flex-col gap-1">
        <p class="text-sm text-white font-semibold" style="font-family: var(--font-sans);">Chimbas</p>
        <a
          href="https://wa.me/5492645743524"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-white/75 hover:text-white transition-colors"
          aria-label="WhatsApp Chimbas"
          style="font-family: var(--font-sans);"
        >
          <svg class="w-4 h-4 fill-current flex-shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          264 574-3524
        </a>
      </div>

    </div>

    <!-- Columna 4: Horarios y urgencias -->
    <div class="flex flex-col gap-3">
      <h3 class="font-bold text-white text-sm mb-1" style="font-family: var(--font-sans);">Atención</h3>
      <div class="flex flex-col gap-1 text-sm text-white/70" style="font-family: var(--font-sans);">
        <p class="font-semibold text-white">Lun – Vie</p>
        <p>9:00–13:00 y 16:00–20:00</p>
        <p class="font-semibold text-white mt-1">Sábado</p>
        <p>9:30–13:00</p>
      </div>
      <div class="mt-1 pt-3 border-t border-white/20 flex flex-col gap-0.5">
        <p class="text-xs font-bold text-white flex items-center gap-1" style="font-family: var(--font-sans);">
          <span class="material-symbols-outlined text-sm" aria-hidden="true">emergency</span>
          Urgencias 24hs
        </p>
        <a
          href="tel:2643220000"
          class="text-sm font-extrabold text-white hover:opacity-80 transition-opacity"
          style="font-family: var(--font-sans);"
          aria-label="Línea de emergencias veterinarias"
        >
          264 322-0000
        </a>
        <p class="text-xs text-white/60" style="font-family: var(--font-sans);">Lun–Sáb 21–09 · Dom y feriados 24hs</p>
      </div>
    </div>

  </div>

  <!-- Copyright -->
  <div class="max-w-7xl mx-auto mt-7 pt-5 border-t border-white/20 text-center text-xs text-white/50" style="font-family: var(--font-sans);">
    © {year} Maskotitas Veterinaria · San Juan, Argentina
  </div>
</footer>
