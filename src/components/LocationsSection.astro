---
import { locations } from '../data/locations';
---

<section id="sucursales" class="py-20 px-8 bg-surface">
  <div class="max-w-7xl mx-auto">

    <!-- Encabezado -->
    <div class="section-fade text-center max-w-2xl mx-auto mb-14">
      <h2 class="text-3xl md:text-4xl font-extrabold text-on-surface mb-4">Nuestras Sucursales</h2>
      <p class="text-lg text-on-surface-variant leading-relaxed">
        Estamos cerca tuyo para cuidar a tu mascota.
      </p>
    </div>

    <!-- Grid de sucursales -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {locations.map((loc) => (
        <div class="section-fade flex flex-col gap-6">
          <!-- Imagen placeholder (mapa) -->
          <div class="h-60 rounded-2xl overflow-hidden bg-surface-container-high border border-outline-variant/20 shadow-sm">
            <img
              src={`https://picsum.photos/seed/${loc.imageSeed}/800/400`}
              alt={`Zona de la ${loc.nombre}`}
              loading="lazy"
              width="800"
              height="400"
              class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500"
            />
          </div>

          <!-- Info -->
          <div>
            <div class="flex items-center gap-2 mb-2">
              <span
                class={['material-symbols-outlined', loc.color === 'primary' ? 'text-primary' : 'text-secondary'].join(' ')}
                aria-hidden="true"
              >
                location_on
              </span>
              <h3 class="text-xl font-bold text-on-surface">{loc.nombre}</h3>
            </div>
            <p class="text-on-surface-variant text-base pl-8 mb-4">{loc.direccion}</p>
            <div class="pl-8 flex flex-col gap-2">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-sm text-outline" aria-hidden="true">schedule</span>
                <span class="text-sm text-on-surface-variant">Lun–Vie 9–13 y 16–20 · Sáb 9:30–13</span>
              </div>
              <a
                href={`tel:${loc.telefono}`}
                class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary-container transition-colors"
                aria-label={`Llamar a la ${loc.nombre}: ${loc.telefonoDisplay}`}
              >
                <span class="material-symbols-outlined text-sm" aria-hidden="true">call</span>
                {loc.telefonoDisplay}
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
