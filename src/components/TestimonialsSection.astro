---
import { testimonials } from '../data/testimonials';
---

<section id="testimonios" class="py-20 bg-surface-container-lowest border-y border-outline-variant/20">
  <!-- Encabezado -->
  <div class="max-w-7xl mx-auto px-8 mb-14">
    <div class="section-fade text-center max-w-2xl mx-auto">
      <h2 class="text-4xl md:text-5xl font-bold text-on-surface mb-4">
        Reseñas
      </h2>
      <p class="text-xl text-on-surface-variant leading-relaxed italic" style="font-family: var(--font-display);">
        Lo que dicen las familias que confían en nosotros.
      </p>
    </div>
  </div>

  <!-- Carousel con flechas -->
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    <div class="flex items-center gap-3">

      <!-- Flecha izquierda -->
      <button
        id="testimonials-prev"
        aria-label="Reseña anterior"
        class="carousel-btn flex-shrink-0 w-10 h-10 bg-surface rounded-full shadow-md border border-outline-variant/30 flex items-center justify-center text-on-surface hover:bg-surface-container hover:border-secondary/30 transition-all disabled:opacity-30 disabled:cursor-not-allowed"
      >
        <span class="material-symbols-outlined text-xl" aria-hidden="true">chevron_left</span>
      </button>

      <!-- Carousel -->
      <div id="testimonials-carousel" class="snap-carousel hide-scrollbar select-none flex-1">
        {testimonials.map((t) => (
          <div class="w-[320px] md:w-[420px] bg-surface p-7 rounded-3xl shadow-sm border border-outline-variant/20 flex flex-col">
            <div class="flex gap-0.5 mb-4 text-amber-400 text-xl leading-none" aria-label="5 estrellas">
              {[0,1,2,3,4].map(() => (
                <span aria-hidden="true">★</span>
              ))}
            </div>
            <p class="text-on-surface-variant text-base leading-relaxed italic flex-grow mb-5" style="font-family: var(--font-display);">
              "{t.texto}"
            </p>
            <div class="flex items-center gap-3">
              <div
                class={[
                  'w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0',
                  t.color === 'primary' ? 'bg-primary/15 text-primary' : 'bg-secondary/15 text-secondary',
                ].join(' ')}
                aria-hidden="true"
              >
                {t.inicial}
              </div>
              <span class="font-semibold text-on-surface text-sm" style="font-family: var(--font-sans);">{t.autor}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Flecha derecha -->
      <button
        id="testimonials-next"
        aria-label="Reseña siguiente"
        class="carousel-btn flex-shrink-0 w-10 h-10 bg-surface rounded-full shadow-md border border-outline-variant/30 flex items-center justify-center text-on-surface hover:bg-surface-container hover:border-secondary/30 transition-all disabled:opacity-30 disabled:cursor-not-allowed"
      >
        <span class="material-symbols-outlined text-xl" aria-hidden="true">chevron_right</span>
      </button>

    </div>
  </div>
</section>

<script>
  import { enableCarousel } from '../scripts/carousel';

  const carousel = document.getElementById('testimonials-carousel') as HTMLElement | null;
  const prevBtn  = document.getElementById('testimonials-prev')    as HTMLButtonElement | null;
  const nextBtn  = document.getElementById('testimonials-next')    as HTMLButtonElement | null;

  if (carousel) {
    enableCarousel(carousel);

    const STEP = 420 + 24;

    function syncArrows() {
      if (!prevBtn || !nextBtn) return;
      prevBtn.disabled = carousel.scrollLeft <= 1;
      nextBtn.disabled = carousel.scrollLeft >= carousel.scrollWidth - carousel.clientWidth - 1;
    }

    prevBtn?.addEventListener('click', () => {
      carousel.scrollBy({ left: -STEP, behavior: 'smooth' });
    });

    nextBtn?.addEventListener('click', () => {
      carousel.scrollBy({ left: STEP, behavior: 'smooth' });
    });

    carousel.addEventListener('scroll', syncArrows, { passive: true });
    syncArrows();
  }
</script>
