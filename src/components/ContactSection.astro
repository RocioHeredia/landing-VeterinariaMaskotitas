---
import { services } from '../data/services';
import { locations } from '../data/locations';

const especies = ['Perro', 'Gato', 'Ave', 'Conejo', 'Otro'];
const horarios = [
  { value: 'Mañana (9:00 – 13:00)', label: 'Mañana (9:00 – 13:00)' },
  { value: 'Tarde (16:00 – 20:00)', label: 'Tarde (16:00 – 20:00)' },
];
---

<section id="contacto" class="py-20 px-8 bg-surface-container-low">
  <div class="max-w-3xl mx-auto">

    <!-- Encabezado -->
    <div class="section-fade text-center mb-12">
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-2 rounded-full text-sm font-semibold mb-4">
        <span class="material-symbols-outlined text-lg" aria-hidden="true">calendar_month</span>
        Reserva de Turno
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-on-surface mb-3">
        Agendá tu turno
      </h2>
      <p class="text-xl text-on-surface-variant leading-relaxed italic" style="font-family: var(--font-display);">
        Completá el formulario y te contactamos por WhatsApp para confirmar.
      </p>
    </div>

    <!-- Formulario -->
    <form
      id="contact-form"
      novalidate
      class="section-fade bg-surface-container-lowest rounded-3xl p-8 md:p-10 shadow-sm border border-outline-variant/20 flex flex-col gap-5"
    >
      <!-- Fila: Nombre + Teléfono -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="flex flex-col gap-1.5">
          <label for="nombre" class="text-sm font-semibold text-on-surface">
            Nombre <span class="text-error" aria-hidden="true">*</span>
          </label>
          <input
            id="nombre"
            name="nombre"
            type="text"
            required
            autocomplete="given-name"
            placeholder="Tu nombre"
            class="form-input"
          />
        </div>
        <div class="flex flex-col gap-1.5">
          <label for="telefono" class="text-sm font-semibold text-on-surface">
            Teléfono <span class="text-error" aria-hidden="true">*</span>
          </label>
          <input
            id="telefono"
            name="telefono"
            type="tel"
            required
            autocomplete="tel"
            placeholder="264 000-0000"
            class="form-input"
          />
        </div>
      </div>

      <!-- Fila: Nombre mascota + Especie -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="flex flex-col gap-1.5">
          <label for="nombre-mascota" class="text-sm font-semibold text-on-surface">
            Nombre de la mascota <span class="text-error" aria-hidden="true">*</span>
          </label>
          <input
            id="nombre-mascota"
            name="nombre-mascota"
            type="text"
            required
            placeholder="Nombre de tu mascota"
            class="form-input"
          />
        </div>
        <div class="flex flex-col gap-1.5">
          <label for="especie" class="text-sm font-semibold text-on-surface">
            Especie <span class="text-error" aria-hidden="true">*</span>
          </label>
          <select id="especie" name="especie" required class="form-input">
            <option value="" disabled selected>Seleccioná la especie</option>
            {especies.map(e => <option value={e}>{e}</option>)}
          </select>
        </div>
      </div>

      <!-- Servicio -->
      <div class="flex flex-col gap-1.5">
        <label for="servicio" class="text-sm font-semibold text-on-surface">
          Servicio <span class="text-error" aria-hidden="true">*</span>
        </label>
        <select id="servicio" name="servicio" required class="form-input">
          <option value="" disabled selected>Seleccioná el servicio</option>
          {services.map(s => (
            <option value={s.nombre}>{s.nombre} — {s.descripcion}</option>
          ))}
        </select>
      </div>

      <!-- Sede -->
      <div class="flex flex-col gap-1.5">
        <label for="sede" class="text-sm font-semibold text-on-surface">
          Sede <span class="text-error" aria-hidden="true">*</span>
        </label>
        <select id="sede" name="sede" required class="form-input">
          <option value="" disabled selected>Seleccioná la sucursal</option>
          {locations.map(loc => (
            <option value={`${loc.nombre} — ${loc.direccion}`}>{loc.nombre} — {loc.direccion}</option>
          ))}
        </select>
      </div>

      <!-- Fila: Fecha + Horario -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="flex flex-col gap-1.5">
          <label for="fecha" class="text-sm font-semibold text-on-surface">
            Fecha <span class="text-error" aria-hidden="true">*</span>
          </label>
          <input
            id="fecha"
            name="fecha"
            type="date"
            required
            class="form-input"
          />
        </div>
        <div class="flex flex-col gap-1.5">
          <label for="horario" class="text-sm font-semibold text-on-surface">
            Horario <span class="text-error" aria-hidden="true">*</span>
          </label>
          <select id="horario" name="horario" required class="form-input">
            <option value="" disabled selected>Seleccioná el horario</option>
            {horarios.map(h => <option value={h.value}>{h.label}</option>)}
          </select>
        </div>
      </div>

      <!-- Comentario -->
      <div class="flex flex-col gap-1.5">
        <label for="comentario" class="text-sm font-semibold text-on-surface">
          Comentario adicional
        </label>
        <textarea
          id="comentario"
          name="comentario"
          rows="3"
          placeholder="Síntomas, consultas previas, o cualquier información que nos ayude a preparar la atención..."
          class="form-input resize-none"
        ></textarea>
      </div>

      <!-- Mensaje de error -->
      <p id="form-error" class="hidden text-sm text-error font-medium" role="alert" aria-live="polite"></p>

      <!-- Submit -->
      <button
        type="submit"
        class="w-full inline-flex items-center justify-center gap-3 bg-primary text-on-primary font-bold py-4 px-8 rounded-full hover:bg-primary/90 active:scale-[0.98] transition-all duration-200 shadow-md shadow-primary/20 text-base mt-2"
      >
        <span class="material-symbols-outlined" aria-hidden="true">send</span>
        Solicitar Turno por WhatsApp
      </button>

      <p class="text-xs text-on-surface-variant text-center">
        Al enviar, se abrirá WhatsApp con tus datos pre-completados para confirmar el turno.
      </p>
    </form>
  </div>
</section>

<style>
  .form-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    border: 1.5px solid var(--color-outline-variant);
    background-color: var(--color-surface);
    color: var(--color-on-surface);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    appearance: auto;
  }
  .form-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 15%, transparent);
  }
  .form-input::placeholder {
    color: var(--color-outline);
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const errorMsg = document.getElementById('form-error');

  // Fecha mínima: hoy
  const fechaInput = document.getElementById('fecha') as HTMLInputElement | null;
  if (fechaInput) {
    fechaInput.min = new Date().toISOString().split('T')[0];
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);

    const nombre       = (data.get('nombre') as string).trim();
    const telefono     = (data.get('telefono') as string).trim();
    const mascota      = (data.get('nombre-mascota') as string).trim();
    const especie      = data.get('especie') as string;
    const servicio     = data.get('servicio') as string;
    const sede         = data.get('sede') as string;
    const fechaRaw     = data.get('fecha') as string;
    const horario      = data.get('horario') as string;
    const comentario   = (data.get('comentario') as string).trim();

    // Formatear fecha en español
    const fechaDisplay = fechaRaw
      ? new Date(fechaRaw + 'T12:00:00').toLocaleDateString('es-AR', {
          weekday: 'long',
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        })
      : fechaRaw;

    const lineas = [
      '🐾 *Solicitud de Turno — Maskotitas Veterinaria*',
      '',
      `👤 *Nombre:* ${nombre}`,
      `📞 *Teléfono:* ${telefono}`,
      `🐾 *Mascota:* ${mascota} (${especie})`,
      `🏥 *Servicio:* ${servicio}`,
      `📍 *Sede:* ${sede}`,
      `📅 *Fecha:* ${fechaDisplay}`,
      `🕐 *Horario:* ${horario}`,
      comentario ? `💬 *Comentario:* ${comentario}` : '',
    ].filter(Boolean);

    const text = encodeURIComponent(lineas.join('\n'));
    window.open(`https://wa.me/542643220000?text=${text}`, '_blank');
  });
</script>
