---
---

<section id="inicio" class="hero-section relative pt-36 pb-24 px-8 overflow-hidden bg-white min-h-[85vh] flex items-center">

  <!-- ── Fotos dispersas estilo polaroid ── -->

  <!-- 1: Perro — arriba izquierda -->
  <div
    aria-hidden="true"
     class="absolute top-32 sm:top-36 left-2 sm:left-6 lg:left-10 -rotate-6 z-0 transition-transform duration-300 hover:scale-105 hover:-rotate-3">
    <div class="bg-white p-2 pb-4 rounded-xl shadow-2xl border border-outline-variant/20">
      <img
        src="/pet1.jpeg"
        alt=""
        role="presentation"
        loading="eager"
        width="300"
        height="300"
        class="w-20 h-20 sm:w-28 sm:h-28 lg:w-36 lg:h-36 object-cover rounded-lg block"
      />
    </div>
  </div>

  <!-- 2: Gato — arriba derecha -->
  <div
    aria-hidden="true"
    class="absolute top-32 sm:top-36 right-2 sm:right-6 lg:right-10 rotate-6 z-0 transition-transform duration-300 hover:scale-105 hover:rotate-3">
    <div class="bg-white p-2 pb-4 rounded-xl shadow-2xl border border-outline-variant/20">
      <img
        src="/pet2.jpeg"
        alt=""
        role="presentation"
        loading="eager"
        width="300"
        height="300"
        class="w-20 h-20 sm:w-28 sm:h-28 lg:w-36 lg:h-36 object-cover rounded-lg block"
      />
    </div>
  </div>

  <!-- 3: Gato — centro izquierda (md+) -->
  <div
    aria-hidden="true"
    class="hidden md:block absolute top-1/2 -translate-y-1/2 left-4 lg:left-8 -rotate-3 z-0 transition-transform duration-300 hover:scale-105"
  >
    <div class="bg-white p-2 pb-4 rounded-xl shadow-2xl border border-outline-variant/20">
      <img
        src="/pet3.jpeg"
        alt=""
        role="presentation"
        loading="lazy"
        width="300"
        height="300"
        class="w-20 h-20 md:w-28 md:h-28 lg:w-36 lg:h-36 object-cover rounded-lg block"
      />
    </div>
  </div>

  <!-- 4: Perro — centro derecha (md+) -->
  <div
    aria-hidden="true"
    class="hidden md:block absolute top-1/2 -translate-y-1/2 right-4 lg:right-8 rotate-3 z-0 transition-transform duration-300 hover:scale-105"
  >
    <div class="bg-white p-2 pb-4 rounded-xl shadow-2xl border border-outline-variant/20">
      <img
        src="/pet4.jpeg"
        alt=""
        role="presentation"
        loading="lazy"
        width="300"
        height="300"
        class="w-20 h-20 md:w-28 md:h-28 lg:w-36 lg:h-36 object-cover rounded-lg block"
      />
    </div>
  </div>

  <!-- 5: Perro — abajo izquierda -->
  <div
    aria-hidden="true"
    class="absolute bottom-10 left-2 sm:left-6 lg:left-16 rotate-2 z-0 transition-transform duration-300 hover:scale-105"
  >
    <div class="bg-white p-2 pb-4 rounded-xl shadow-2xl border border-outline-variant/20">
      <img
        src="/pet5.jpeg"
        alt=""
        role="presentation"
        loading="lazy"
        width="300"
        height="300"
        class="w-20 h-20 sm:w-24 sm:h-24 lg:w-36 lg:h-36 object-cover rounded-lg block"
      />
    </div>
  </div>

  <!-- 6: Gato — abajo derecha -->
  <div
    aria-hidden="true"
    class="absolute bottom-8 right-2 sm:right-6 lg:right-16 -rotate-6 z-0 transition-transform duration-300 hover:scale-105 hover:-rotate-3">
    <div class="bg-white p-2 pb-4 rounded-xl shadow-2xl border border-outline-variant/20">
      <img
        src="/pet6.jpeg"
        alt=""
        role="presentation"
        loading="lazy"
        width="300"
        height="300"
        class="w-20 h-20 sm:w-24 sm:h-24 lg:w-36 lg:h-36 object-cover rounded-lg block"
      />
    </div>
  </div>

  <!-- Contenido principal -->
  <div class="relative z-10 max-w-3xl mx-auto flex flex-col items-center text-center gap-6 w-full">

    <div class="hero-badge inline-flex items-center gap-1 sm:gap-2 bg-secondary/10 text-secondary px-2 py-1 sm:px-5 sm:py-2.5 rounded-full w-fit font-semibold" style="font-size: clamp(7px, 1.8vw, 0.875rem);">
      <span class="material-symbols-outlined text-xs sm:text-lg" aria-hidden="true">pets</span>
      Clínica Veterinaria · Emergencias 24hs
    </div>

    <h1 class="hero-title font-bold text-on-surface leading-tight mt-8" style="font-size: clamp(2.6rem, 5.5vw, 4.2rem);">
      Cuidado profesional con amor para tus mejores amigos
    </h1>

    <p class="hero-desc text-lg text-on-surface-variant leading-relaxed max-w-xl" style="font-family: var(--font-sans);">
      En Maskotitas combinamos la precisión clínica con el cariño que tu mascota merece. Dos sucursales en San Juan, equipo dedicado y emergencias 24hs.
    </p>

    <div class="hero-cta mt-2">
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 sm:gap-3 bg-primary text-on-primary font-bold px-6 py-3 sm:px-10 sm:py-4 rounded-full hover:bg-primary/90 active:scale-[0.98] transition-all duration-200 shadow-lg shadow-primary/25 text-sm sm:text-base"
        style="font-family: var(--font-sans);"
      >
        <span class="material-symbols-outlined" aria-hidden="true">calendar_month</span>
        Reservar Turno
      </a>
    </div>
  </div>
</section>
