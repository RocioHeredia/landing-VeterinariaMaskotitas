<section class="bg-error/10 border-y border-error/20 py-8 px-8">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="flex items-center gap-4">
      <div class="bg-error text-on-error p-3 rounded-full flex-shrink-0 shadow-sm">
        <span class="material-symbols-outlined" aria-hidden="true">emergency</span>
      </div>
      <div>
        <h2 class="text-lg font-bold text-error mb-0.5">Emergencias Veterinarias</h2>
        <p class="text-sm text-on-surface">
          Lunes a Sábado de 21:00 a 09:00 hs &nbsp;·&nbsp; Domingos y Feriados las 24 hs
          <span class="block text-xs text-on-surface-variant mt-0.5">Atención en consultorios rotativos — no se atiende a domicilio</span>
        </p>
      </div>
    </div>
    <a
      href="tel:2643220000"
      class="inline-flex items-center gap-2 bg-error text-on-error font-bold px-6 py-3 rounded-xl hover:bg-error/90 transition-colors shadow-sm text-lg tracking-wide flex-shrink-0"
      aria-label="Llamar a emergencias veterinarias: 264 322-0000"
    >
      <span class="material-symbols-outlined" aria-hidden="true">phone</span>
      264 322-0000
    </a>
  </div>
</section>
