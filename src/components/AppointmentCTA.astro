---
---

<section class="py-20 px-8 bg-surface section-fade">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-10 bg-primary p-10 md:p-14 rounded-4xl">

      <!-- Texto -->
      <div class="max-w-xl">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
          ¿Tu mascota necesita una consulta?
        </h2>
        <p class="text-xl text-white/85 mb-8 leading-relaxed italic" style="font-family: var(--font-display);">
          Agendá un turno de manera rápida y sencilla, o escribinos directo por WhatsApp. Nuestro equipo está listo para brindar la mejor atención.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="#contacto"
            class="inline-flex items-center gap-2 bg-white text-primary font-bold px-8 py-4 rounded-full hover:bg-surface transition-colors shadow-lg active:scale-[0.98] text-sm"
            style="font-family: var(--font-sans);"
          >
            <span class="material-symbols-outlined" aria-hidden="true">calendar_today</span>
            Agendar Turno
          </a>
        </div>
      </div>

      <!-- Ícono decorativo -->
      <div class="bg-white/15 p-8 rounded-full flex-shrink-0" aria-hidden="true">
        <span class="material-symbols-outlined text-white" style="font-size: 96px; line-height: 1;">event_available</span>
      </div>

    </div>
  </div>
</section>
