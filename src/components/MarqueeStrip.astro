---
const items = [
  { icon: 'pets',           text: '2 Sucursales en San Juan' },
  { icon: 'emergency',      text: 'Emergencias 24hs' },
  { icon: 'verified',       text: 'Equipo profesional' },
  { icon: 'attach_money',   text: 'Precios accesibles' },
  { icon: 'science',        text: 'Laboratorio propio' },
  { icon: 'content_cut',    text: 'Peluquería especializada' },
  { icon: 'local_hospital', text: 'Internación monitoreada' },
  { icon: 'storefront',     text: 'Farmacia y Pet Shop' },
];

// 4 copias para loop perfecto
const repeated = [...items, ...items, ...items, ...items];
---

<div
  class="overflow-hidden border-y border-outline-variant/20 bg-surface-container-low py-4 select-none"
  aria-hidden="true"
>
  <div class="flex gap-12">
    {[0, 1, 2, 3].map(() => (
      <div class="marquee-track items-center">
        {items.map(item => (
          <span class="inline-flex items-center gap-2 text-sm font-semibold text-on-surface-variant whitespace-nowrap">
            <span class="material-symbols-outlined text-primary text-[18px]">{item.icon}</span>
            {item.text}
          </span>
        ))}
      </div>
    ))}
  </div>
</div>
